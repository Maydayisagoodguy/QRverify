# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
VERIFY_BASE_URL=https://verify.yourdomain.com

# ── Crypto  (generate with: npm run keygen) ───────────────────────
HMAC_SECRET=replace-with-64-char-random-string

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Upstash Redis ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Resend (email alerts) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=ops@yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_API_KEY=replace-with-another-long-random-string
